{% extends "base.html.j2" %}

{% block body_content %}
<div class="page-wrapper">
    {# ── Sticky Sidebar TOC ── #}
    <nav class="sidebar" id="toc">
        <a href="#top" class="toc-title">Table of Contents</a>
        <input type="text" id="toc-search" class="sidebar-search" placeholder="Search terms...">
        <ul class="toc-list">
            {% if sections %}
            {% for section in sections %}
            <li><a href="#section-{{ section.filename | replace('.md','') | replace('_','') }}">{{ section.section | capitalize }}</a></li>
            {% endfor %}
            {% endif %}
            {% if classes %}<li><a href="#concept-hierarchy">Concept Hierarchy</a></li>{% endif %}
            {% if classes %}<li>
                <a href="#classes" class="toc-section-link">Classes <span class="toc-count">{{ classes | length }}</span></a>
                <ul class="toc-sub">
                {% for cls in classes %}
                    <li><a href="#{{ cls.local_name }}">{{ cls.local_name }}</a></li>
                {% endfor %}
                </ul>
            </li>{% endif %}
            {% if properties %}<li>
                <a href="#properties" class="toc-section-link">Properties <span class="toc-count">{{ properties | length }}</span></a>
                <ul class="toc-sub">
                {% for prop in properties %}
                    <li><a href="#{{ prop.local_name }}">{{ prop.local_name }}</a></li>
                {% endfor %}
                </ul>
            </li>{% endif %}
            {% if shapes %}<li>
                <a href="#shapes" class="toc-section-link">SHACL Shapes <span class="toc-count">{{ shapes | length }}</span></a>
                <ul class="toc-sub">
                {% for shape in shapes %}
                    <li><a href="#{{ shape.local_name }}">{{ shape.local_name }}</a></li>
                {% endfor %}
                </ul>
            </li>{% endif %}
            {% if conneg.formats %}<li>
                <a href="#serializations" class="toc-section-link">Serializations <span class="toc-count">{{ conneg.formats | reject('equalto', 'html') | list | length }}</span></a>
                <ul class="toc-sub">
                {% for fmt in conneg.formats %}
                    {% if fmt == 'ttl' %}<li><a href="ontology.ttl">Turtle</a></li>{% endif %}
                    {% if fmt == 'jsonld' %}<li><a href="ontology.jsonld">JSON-LD</a></li>{% endif %}
                    {% if fmt == 'nt' %}<li><a href="ontology.nt">N-Triples</a></li>{% endif %}
                    {% if fmt == 'owl' %}<li><a href="ontology.owl">RDF/XML</a></li>{% endif %}
                {% endfor %}
                </ul>
            </li>{% endif %}
        </ul>
    </nav>

    <div class="content" id="top">

    {# ── ReSpec-style Metadata Header ── #}
    <div class="respec-header">
        <h1>{{ metadata.title }}</h1>
        {% if metadata.description %}
        <p class="subtitle">{{ metadata.description }}</p>
        {% endif %}
        <p class="subtitle">version {{ metadata.version }}</p>
        {% if metadata.status and metadata.date %}
        <p class="doc-status">{{ metadata.status }} {{ metadata.date }}</p>
        {% elif metadata.status %}
        <p class="doc-status">{{ metadata.status }}</p>
        {% endif %}

        <dl>
            <dt>This version:</dt>
            <dd><a href="{{ conneg.base_uri or metadata.namespace }}">{{ conneg.base_uri or metadata.namespace }}</a></dd>

            {% if metadata.previous_version %}
            <dt>Previous version:</dt>
            <dd><a href="{{ metadata.previous_version }}">{{ metadata.previous_version }}</a></dd>
            {% endif %}

            {% if metadata.editors %}
            <dt>Editor{{ 's' if metadata.editors | length > 1 }}:</dt>
            {% for ed in metadata.editors %}
            <dd>{% if ed.url %}<a href="{{ ed.url }}">{{ ed.name }}</a>{% else %}{{ ed.name }}{% endif %}{% if ed.orcid %} <a href="https://orcid.org/{{ ed.orcid }}" class="orcid-link" title="ORCID"><svg class="orcid-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path fill="#a6ce39" d="M128 0C57.3 0 0 57.3 0 128s57.3 128 128 128 128-57.3 128-128S198.7 0 128 0zM86.3 186.2H70.9V79.1h15.4v107.1zM78.6 70.6c-5.7 0-10.3-4.6-10.3-10.3s4.6-10.3 10.3-10.3 10.3 4.6 10.3 10.3-4.6 10.3-10.3 10.3zM196.9 186.2h-15.4v-55.8c0-17.3-6.5-29.2-21.7-29.2-11.8 0-18.9 8-22 15.6-.7 1.8-1.2 5.5-1.2 7.4v62h-15.4V79.1h15.4v14.8c5.7-8.6 15.2-14.8 27.7-14.8 20.2 0 32.6 13.2 32.6 41.5v65.6z"/></svg></a>{% endif %}{% if ed.affiliation %} ({{ ed.affiliation }}){% endif %}</dd>
            {% endfor %}
            {% endif %}

            {% if metadata.authors %}
            <dt>Author{{ 's' if metadata.authors | length > 1 }}:</dt>
            {% for au in metadata.authors %}
            <dd>{% if au.url %}<a href="{{ au.url }}">{{ au.name }}</a>{% else %}{{ au.name }}{% endif %}{% if au.orcid %} <a href="https://orcid.org/{{ au.orcid }}" class="orcid-link" title="ORCID"><svg class="orcid-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path fill="#a6ce39" d="M128 0C57.3 0 0 57.3 0 128s57.3 128 128 128 128-57.3 128-128S198.7 0 128 0zM86.3 186.2H70.9V79.1h15.4v107.1zM78.6 70.6c-5.7 0-10.3-4.6-10.3-10.3s4.6-10.3 10.3-10.3 10.3 4.6 10.3 10.3-4.6 10.3-10.3 10.3zM196.9 186.2h-15.4v-55.8c0-17.3-6.5-29.2-21.7-29.2-11.8 0-18.9 8-22 15.6-.7 1.8-1.2 5.5-1.2 7.4v62h-15.4V79.1h15.4v14.8c5.7-8.6 15.2-14.8 27.7-14.8 20.2 0 32.6 13.2 32.6 41.5v65.6z"/></svg></a>{% endif %}{% if au.affiliation %} ({{ au.affiliation }}){% endif %}</dd>
            {% endfor %}
            {% endif %}

            {% if metadata.repository %}
            <dt>Feedback:</dt>
            <dd><a href="{{ metadata.repository }}">{{ metadata.repository }}</a>
                (<a href="{{ metadata.repository }}/pulls">pull requests</a>,
                 <a href="{{ metadata.repository }}/issues/new">new issue</a>,
                 <a href="{{ metadata.repository }}/issues">open issues</a>)</dd>
            {% endif %}

            <dt>Namespace:</dt>
            <dd><code>{{ metadata.namespace }}</code></dd>

            <dt>Prefix:</dt>
            <dd><code>{{ metadata.prefix }}</code></dd>

            <dt>License:</dt>
            <dd>{{ metadata.license }}</dd>

            {% if conneg.formats %}
            <dt>Serializations:</dt>
            <dd>
                {% for fmt in conneg.formats %}
                    {% if fmt == 'ttl' %}<a href="ontology.ttl">Turtle</a>{% endif %}
                    {% if fmt == 'jsonld' %}<a href="ontology.jsonld">JSON-LD</a>{% endif %}
                    {% if fmt == 'nt' %}<a href="ontology.nt">N-Triples</a>{% endif %}
                    {% if fmt == 'owl' %}<a href="ontology.owl">RDF/XML</a>{% endif %}
                    {% if not loop.last %} | {% endif %}
                {% endfor %}
            </dd>
            {% endif %}
        </dl>

        {% if metadata.copyright %}
        <p class="copyright">{{ metadata.copyright }}</p>
        {% endif %}

        {% if metadata.contributors %}
        <p class="contributors"><strong>Contributors:</strong> {{ metadata.contributors | join(', ') }}</p>
        {% endif %}
    </div>

    {# ── Narrative Sections ── #}
    {% for section in sections %}
    <section class="narrative" id="section-{{ section.filename | replace('.md','') | replace('_','') }}">
        {{ section.html | safe }}
    </section>
    {% endfor %}

    {# ── Concept Hierarchy ── #}
    {% if classes %}
    {% macro render_tree(nodes) %}
    <ul>
        {% for node in nodes %}
        <li>
            {% if node.is_individual %}
            <a href="#{{ node.local_name }}" class="tree-term tree-individual"
               data-term-id="{{ node.local_name }}"
               data-is-individual="true"
               data-label="{{ node.label or node.local_name }}"
               data-iri="{{ node.iri }}"
               {% if node.comment %}data-comment="{{ node.comment }}"{% endif %}
               {% if node.types %}data-types="{{ node.types | join(',') }}"{% endif %}
               {% if node.comment %}title="{{ node.comment }}"{% endif %}
            >{{ node.label or node.local_name }}</a>
            {% else %}
            <a href="#{{ node.local_name }}" class="tree-term"
               data-term-id="{{ node.local_name }}"
               {% if node.comment %}title="{{ node.comment }}"{% endif %}
            >{{ node.label or node.local_name }}</a>
            {% endif %}
            {% if node.children %}{{ render_tree(node.children) }}{% endif %}
        </li>
        {% endfor %}
    </ul>
    {% endmacro %}
    <section id="concept-hierarchy">
        <h2>Concept Hierarchy</h2>
        <div class="hierarchy-section">
            <div class="hierarchy-left">
                <div class="hierarchy-tree">
                    {{ render_tree(hierarchy) }}
                </div>
            </div>
            <div class="hierarchy-right" id="hierarchy-detail">
                <p class="detail-empty">Click a term to see details</p>
            </div>
        </div>
    </section>
    {% endif %}

    {# ── Classes ── #}
    {% if classes %}
    <section id="classes">
        <h2>Classes</h2>
        {% for cls in classes %}
        <div class="term-def" id="{{ cls.local_name }}">
            <h3>{{ cls.prefixed_name }}
                <a href="classes/{{ cls.local_name }}.html" title="Standalone page" style="font-size:0.75em; font-weight:normal;">&#x1f517;</a>
            </h3>
            <table class="term-contents">
                <tr><th>Term</th><td><code>{{ cls.prefixed_name }}</code></td></tr>
                {% if cls.label %}<tr><th>Label</th><td>{{ cls.label }}</td></tr>{% endif %}
                <tr><th>IRI</th><td><code>{{ cls.iri }}</code></td></tr>
                <tr><th>Type</th><td><code>rdfs:Class</code></td></tr>
                {% if cls.superclasses %}
                <tr><th>Broader/Parent types</th><td>
                    {% for sc in cls.superclasses %}{{ sc | term_link }}{% if not loop.last %}, {% endif %}{% endfor %}
                </td></tr>
                {% endif %}
                {% if cls.subclasses %}
                <tr><th>Narrower/Child types</th><td>
                    {% for sc in cls.subclasses %}{{ sc | term_link }}{% if not loop.last %}, {% endif %}{% endfor %}
                </td></tr>
                {% endif %}
                {% if cls.instances %}
                <tr><th>Instances</th><td>
                    {% for ind in cls.instances %}
                    <span class="instance-chip">{{ ind.label or ind.local_name }}</span>{% if not loop.last %}, {% endif %}
                    {% endfor %}
                </td></tr>
                {% endif %}
                {% if cls.subject_of %}
                <tr><th>Subject of</th><td>
                    {% for p in cls.subject_of %}{{ p | term_link }}{% if not loop.last %}, {% endif %}{% endfor %}
                </td></tr>
                {% endif %}
                {% if cls.object_of %}
                <tr><th>Object of</th><td>
                    {% for p in cls.object_of %}{{ p | term_link }}{% if not loop.last %}, {% endif %}{% endfor %}
                </td></tr>
                {% endif %}
                {% if cls.comment %}<tr><th>Definition</th><td>{{ cls.comment }}</td></tr>{% endif %}
            </table>
            {% if cls.sidecar %}
            <div class="sidecar-content">{{ cls.sidecar | safe }}</div>
            {% endif %}
        </div>
        {% endfor %}
    </section>
    {% endif %}

    {# ── Properties ── #}
    {% if properties %}
    <section id="properties">
        <h2>Properties</h2>
        {% for prop in properties %}
        <div class="term-def" id="{{ prop.local_name }}">
            <h3>{{ prop.prefixed_name }}
                <a href="properties/{{ prop.local_name }}.html" title="Standalone page" style="font-size:0.75em; font-weight:normal;">&#x1f517;</a>
            </h3>
            <table class="term-contents">
                <tr><th>Term</th><td><code>{{ prop.prefixed_name }}</code></td></tr>
                {% if prop.label %}<tr><th>Label</th><td>{{ prop.label }}</td></tr>{% endif %}
                <tr><th>IRI</th><td><code>{{ prop.iri }}</code></td></tr>
                <tr><th>Type</th><td><code>{{ prop.prop_type }}</code></td></tr>
                {% if prop.domain %}<tr><th>Domain</th><td>{{ prop.domain | term_link }}</td></tr>{% endif %}
                {% if prop.range %}<tr><th>Range</th><td>{{ prop.range | term_link }}</td></tr>{% endif %}
                {% if prop.comment %}<tr><th>Definition</th><td>{{ prop.comment }}</td></tr>{% endif %}
            </table>
            {% if prop.sidecar %}
            <div class="sidecar-content">{{ prop.sidecar | safe }}</div>
            {% endif %}
        </div>
        {% endfor %}
    </section>
    {% endif %}

    {# ── SHACL Shapes ── #}
    {% if shapes %}
    <section id="shapes">
        <h2>SHACL Shapes</h2>
        {% for shape in shapes %}
        <div class="shape-block" id="{{ shape.local_name }}">
            <h3>{{ shape.prefixed_name }}</h3>
            {% if shape.target_class %}
            <p>Target class: {{ shape.target_class | term_link }}</p>
            {% endif %}
            {% if shape.constraints %}
            <table class="shape-constraints">
                <thead><tr><th>Path</th><th>Min</th><th>Max</th><th>Class</th></tr></thead>
                <tbody>
                {% for c in shape.constraints %}
                <tr>
                    <td>{% if c.path %}{{ c.path | term_link }}{% endif %}</td>
                    <td>{{ c.min_count if c.min_count is not none else '' }}</td>
                    <td>{{ c.max_count if c.max_count is not none else '' }}</td>
                    <td>{% if c.node_class %}{{ c.node_class | term_link }}{% endif %}</td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            {% endif %}
        </div>
        {% endfor %}
    </section>
    {% endif %}

    {# ── Serializations ── #}
    {% if conneg.formats %}
    <section id="serializations">
        <h2>Serializations</h2>
        <ul class="serialization-links">
        {% for fmt in conneg.formats %}
            {% if fmt == 'ttl' %}<li><a href="ontology.ttl">Turtle (.ttl)</a></li>{% endif %}
            {% if fmt == 'jsonld' %}<li><a href="ontology.jsonld">JSON-LD (.jsonld)</a></li>{% endif %}
            {% if fmt == 'nt' %}<li><a href="ontology.nt">N-Triples (.nt)</a></li>{% endif %}
            {% if fmt == 'owl' %}<li><a href="ontology.owl">RDF/XML (.owl)</a></li>{% endif %}
        {% endfor %}
        </ul>
    </section>
    {% endif %}

    </div>{# /.content #}
</div>{# /.page-wrapper #}
{% endblock %}

{% block scripts %}
<script>
(function(){
    /* --- TOC section toggle --- */
    var sectionLinks = document.querySelectorAll('.toc-section-link');
    for (var i = 0; i < sectionLinks.length; i++) {
        sectionLinks[i].addEventListener('click', function(e){
            var sub = this.nextElementSibling;
            if (sub && sub.classList.contains('toc-sub')) {
                e.preventDefault();
                sub.classList.toggle('open');
            }
        });
    }

    /* --- Search --- */
    var searchInput = document.getElementById('toc-search');
    if (searchInput) {
        searchInput.addEventListener('input', function(){
            var q = this.value.toLowerCase().trim();
            var items = document.querySelectorAll('.toc-sub li');
            for (var i = 0; i < items.length; i++) {
                var text = items[i].textContent.toLowerCase();
                items[i].classList.toggle('search-hidden', q && text.indexOf(q) === -1);
            }
            /* Auto-expand sections with matches */
            var subs = document.querySelectorAll('.toc-sub');
            for (var i = 0; i < subs.length; i++) {
                var hasVisible = subs[i].querySelector('li:not(.search-hidden)');
                if (q && hasVisible) subs[i].classList.add('open');
                else if (!q) subs[i].classList.remove('open');
            }
        });
    }

    /* --- Scroll Spy --- */
    var tocLinks = document.querySelectorAll('.toc-list a[href^="#"]');
    var sections = [];
    for (var i = 0; i < tocLinks.length; i++) {
        var id = tocLinks[i].getAttribute('href').slice(1);
        var el = document.getElementById(id);
        if (el) sections.push({link: tocLinks[i], el: el});
    }
    function updateSpy() {
        var scrollY = window.scrollY + 80;
        var active = null;
        for (var i = 0; i < sections.length; i++) {
            if (sections[i].el.offsetTop <= scrollY) active = sections[i].link;
        }
        for (var i = 0; i < tocLinks.length; i++) tocLinks[i].classList.remove('active');
        if (active) active.classList.add('active');
    }
    window.addEventListener('scroll', updateSpy);
    updateSpy();

    /* --- Hierarchy Detail Panel --- */
    var detailPanel = document.getElementById('hierarchy-detail');
    var treeTerms = document.querySelectorAll('.hierarchy-tree .tree-term');
    for (var i = 0; i < treeTerms.length; i++) {
        treeTerms[i].addEventListener('click', function(e){
            e.preventDefault();
            var termId = this.getAttribute('data-term-id');
            var isIndividual = this.getAttribute('data-is-individual') === 'true';

            /* Update selected state */
            for (var j = 0; j < treeTerms.length; j++) treeTerms[j].classList.remove('selected');
            this.classList.add('selected');

            if (!detailPanel) return;

            if (isIndividual) {
                /* Build detail panel from data attributes for individuals */
                var indLabel = this.getAttribute('data-label') || termId;
                var indIri = this.getAttribute('data-iri') || '';
                var indComment = this.getAttribute('data-comment') || '';
                var indTypes = this.getAttribute('data-types') || '';

                /* Helper to shorten IRIs to prefixed form */
                function shorten(iri) {
                    var ns = '{{ metadata.namespace }}';
                    var pfx = '{{ metadata.prefix }}';
                    if (iri.indexOf(ns) === 0) return pfx + ':' + iri.slice(ns.length);
                    return iri;
                }

                var html = '<h3>' + indLabel + '</h3>';
                html += '<div class="detail-row"><dt>Type</dt><dd>Named Individual</dd></div>';
                if (indIri) html += '<div class="detail-iri"><code>' + shorten(indIri) + '</code></div>';
                if (indComment) html += '<div class="detail-def">' + indComment + '</div>';
                if (indTypes) {
                    var typeList = indTypes.split(',');
                    html += '<div class="detail-row"><dt>Instance of</dt><dd>';
                    for (var t = 0; t < typeList.length; t++) {
                        if (t > 0) html += ', ';
                        var shortType = shorten(typeList[t]);
                        var typeId = typeList[t].split('#').pop().split('/').pop();
                        html += '<a href="#' + typeId + '">' + shortType + '</a>';
                    }
                    html += '</dd></div>';
                }

                detailPanel.innerHTML = html;
                return;
            }

            var termDef = document.getElementById(termId);
            if (!termDef) return;

            /* Extract data from term definition table */
            var label = termDef.querySelector('h3');
            var labelText = label ? label.childNodes[0].textContent.trim() : termId;
            var rows = termDef.querySelectorAll('.term-contents tr');
            var info = {};
            for (var r = 0; r < rows.length; r++) {
                var th = rows[r].querySelector('th');
                var td = rows[r].querySelector('td');
                if (th && td) info[th.textContent.trim()] = td.innerHTML;
            }

            /* Build detail panel HTML — focus on what the tree doesn't show */
            var html = '<h3>' + labelText + '</h3>';
            if (info['Definition']) html += '<div class="detail-def">' + info['Definition'] + '</div>';
            if (info['Subject of']) html += '<div class="detail-row"><dt>Subject of</dt><dd>' + info['Subject of'] + '</dd></div>';
            if (info['Object of']) html += '<div class="detail-row"><dt>Object of</dt><dd>' + info['Object of'] + '</dd></div>';
            if (info['Instances']) html += '<div class="detail-row"><dt>Instances</dt><dd>' + info['Instances'] + '</dd></div>';
            if (info['IRI']) html += '<div class="detail-iri">' + info['IRI'] + '</div>';
            html += '<a href="#' + termId + '" class="detail-link">Go to full definition &darr;</a>';

            detailPanel.innerHTML = html;
        });
    }

    /* --- Highlight on arrival --- */
    function highlightTerm(id) {
        var el = document.getElementById(id);
        if (el && el.classList.contains('term-def')) {
            el.classList.remove('highlight');
            void el.offsetWidth; /* force reflow */
            el.classList.add('highlight');
        }
    }
    window.addEventListener('hashchange', function(){
        highlightTerm(location.hash.slice(1));
    });
    document.addEventListener('click', function(e){
        var link = e.target.closest('a[href^="#"]');
        if (!link) return;
        /* Don't interfere with tree-term clicks (handled separately) */
        if (link.classList.contains('tree-term')) return;
        var id = link.getAttribute('href').slice(1);
        var target = document.getElementById(id);
        if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', '#' + id);
            setTimeout(function(){ highlightTerm(id); }, 300);
        }
    });
})();
</script>
{% endblock %}
