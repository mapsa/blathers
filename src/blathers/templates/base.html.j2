<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ metadata.title }}{% endblock %}</title>
    {% if inline_css is defined and inline_css %}
    <style>{{ inline_css }}</style>
    {% else %}
    <link rel="stylesheet" href="{{ base_path }}assets/style.css">
    {% endif %}
</head>
<body>
    <header>
        <nav>
            <a href="{{ base_path }}index.html" class="logo">{{ metadata.title }}</a>
            <span class="version">v{{ metadata.version }}</span>
            <button id="theme-toggle" aria-label="Toggle theme">&#x1f313;</button>
        </nav>
    </header>
    {% block body_content %}
    <main>
        {% block content %}{% endblock %}
    </main>
    {% endblock %}
    <footer>
        <p>Generated by <a href="https://github.com/bigspark/blathers">Blathers</a> &mdash; {{ metadata.version }}</p>
    </footer>
    <script>
    (function(){
        var btn = document.getElementById('theme-toggle');
        var html = document.documentElement;
        var saved = localStorage.getItem('theme');
        if (saved) html.setAttribute('data-theme', saved);
        if (btn) btn.addEventListener('click', function(){
            var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
        });
    })();
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
