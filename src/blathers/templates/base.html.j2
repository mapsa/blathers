<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ metadata.title }}{% endblock %}</title>
    {% if inline_css is defined and inline_css %}
    <style>{{ inline_css }}</style>
    {% else %}
    <link rel="stylesheet" href="{{ base_path }}assets/style.css">
    {% endif %}
</head>
<body>
    <header>
        <nav>
            <a href="{{ base_path }}index.html" class="logo">{{ metadata.title }}</a>
            <span class="version">v{{ metadata.version }}</span>
            <label class="theme-switch" aria-label="Toggle theme">
                <input type="checkbox" id="theme-toggle">
                <span class="theme-slider">
                    <svg class="theme-icon sun" viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M12 7a5 5 0 100 10 5 5 0 000-10zm0-3a1 1 0 01-1-1V1a1 1 0 112 0v2a1 1 0 01-1 1zm0 18a1 1 0 01-1-1v-2a1 1 0 112 0v2a1 1 0 01-1 1zm9-9a1 1 0 010 2h-2a1 1 0 010-2h2zM4 11a1 1 0 010 2H2a1 1 0 010-2h2zm15.07-6.07a1 1 0 010 1.41l-1.42 1.42a1 1 0 11-1.41-1.42l1.42-1.41a1 1 0 011.41 0zM7.76 16.24a1 1 0 010 1.41l-1.42 1.42a1 1 0 11-1.41-1.42l1.41-1.41a1 1 0 011.42 0zm12.31 6.83a1 1 0 01-1.41 0l-1.42-1.42a1 1 0 111.42-1.41l1.41 1.42a1 1 0 010 1.41zM7.76 7.76a1 1 0 01-1.41 0L4.93 6.34a1 1 0 011.42-1.41l1.41 1.42a1 1 0 010 1.41z"/></svg>
                    <svg class="theme-icon moon" viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M12.3 4.9c.4-.2.6-.7.5-1.1s-.6-.8-1-.8C6.8 3.1 3 7.1 3 12c0 5 4 9 9 9 3.8 0 7.1-2.4 8.4-5.9.2-.4 0-.9-.4-1.1-.4-.3-.9-.2-1.2.1-1 .9-2.3 1.4-3.8 1.4-3.3 0-6-2.7-6-6 0-2.2 1.2-4.1 3.3-4.6z"/></svg>
                </span>
            </label>
        </nav>
    </header>
    {% if metadata.status %}
    <div class="status-banner status-{{ metadata.status | lower | replace(' ', '-') }}">{{ metadata.status }}</div>
    {% endif %}
    {% block body_content %}
    <main>
        {% block content %}{% endblock %}
    </main>
    {% endblock %}
    <a href="#" class="back-to-top" id="back-to-top" aria-label="Back to top">&#x2191;</a>
    <footer>
        <p>Generated by <a href="https://github.com/mapsa/blathers">Blathers</a> &mdash; {{ metadata.version }}</p>
    </footer>
    <script>
    (function(){
        var toggle = document.getElementById('theme-toggle');
        var html = document.documentElement;
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        html.setAttribute('data-theme', theme);
        if (toggle) toggle.checked = (theme === 'dark');
        if (toggle) toggle.addEventListener('change', function(){
            var next = this.checked ? 'dark' : 'light';
            html.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
        });
        var btt = document.getElementById('back-to-top');
        if (btt) {
            window.addEventListener('scroll', function(){
                btt.classList.toggle('visible', window.scrollY > 300);
            });
        }
    })();
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
