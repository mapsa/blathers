@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:  <http://purl.org/vocab/vann/> .
@prefix ex:    <http://example.org/test#> .

<http://example.org/test>
    a owl:Ontology ;
    rdfs:label "Test Ontology"@en ;
    rdfs:comment "A minimal test ontology."@en ;
    owl:versionInfo "0.1.0" ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:creator "Test Author" ;
    dcterms:title "Test Ontology" ;
    vann:preferredNamespacePrefix "ex" ;
    vann:preferredNamespaceUri "http://example.org/test#" .

ex:MyClass
    a owl:Class ;
    rdfs:label "My Class"@en ;
    rdfs:comment "A test class."@en ;
    rdfs:subClassOf owl:Thing .

ex:MySubClass
    a owl:Class ;
    rdfs:label "My Sub Class"@en ;
    rdfs:comment "A test subclass."@en ;
    rdfs:subClassOf ex:MyClass .

ex:myProperty
    a owl:ObjectProperty ;
    rdfs:label "my property"@en ;
    rdfs:comment "A test property."@en ;
    rdfs:domain ex:MyClass ;
    rdfs:range ex:MySubClass .

ex:IndividualA
    a ex:MyClass, owl:NamedIndividual ;
    rdfs:label "Individual A"@en ;
    rdfs:comment "A test individual."@en .
