@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix ex:    <http://example.org/test#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

ex:MyClassShape
    a sh:NodeShape ;
    sh:targetClass ex:MyClass ;
    sh:property [
        sh:path ex:myProperty ;
        sh:minCount 1 ;
        sh:class ex:MySubClass ;
    ] .
